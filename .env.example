# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_DB=ft_interview
POSTGRES_USER=ft_user
POSTGRES_PASSWORD=ft_password
# Change if you already have Postgres on 5432 (e.g. POSTGRES_HOST_PORT=5433).
POSTGRES_HOST_PORT=5432

# ─── Hono backend ───────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Amadeus (Hotel Search API) ─────────────────────────────────────────────
# Free sandbox credentials: https://developers.amadeus.com/register
# Create an app, copy its API Key (client id) and Secret here. Stays in "test"
# mode until you upgrade — that's what we want.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# ─── Frontend ───────────────────────────────────────────────────────────────
# Browser hits this URL; default points at the host-mapped backend port.
NEXT_PUBLIC_API_URL=http://localhost:8000
