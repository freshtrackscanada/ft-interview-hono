# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_DB=ft_interview
POSTGRES_USER=ft_user
POSTGRES_PASSWORD=ft_password
# Change if you already have Postgres on 5432 (e.g. POSTGRES_HOST_PORT=5433).
POSTGRES_HOST_PORT=5432

# ─── Hono backend ───────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Hotel Search ───────────────────────────────────────────────────────────
# 'mock' (default) — in-process fixtures with realistic hotel data for
#                    PAR, LON, NYC, MAD. No credentials needed.
# 'live'           — call the real Amadeus client. NOTE: Amadeus is shutting
#                    down its self-service portal in July 2026; if you have
#                    credentials for an Amadeus-compatible provider, point
#                    AMADEUS_BASE_URL at it.
AMADEUS_MODE=mock
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# ─── Frontend ───────────────────────────────────────────────────────────────
# Browser hits this URL; default points at the host-mapped backend port.
NEXT_PUBLIC_API_URL=http://localhost:8000
